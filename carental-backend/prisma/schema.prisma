generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  OWNER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  phone        String   @unique
  password     String
  role         Role
  profileImage String?

  vehicles      Vehicle[]
  bookings      Booking[]
  reviews       Review[]
  wishlistItems Wishlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id                 String   @id @default(uuid())
  ownerId            String
  name               String
  brand              String
  model              String
  year               Int
  vehicleType        String
  fuelType           String
  transmission       String
  seatingCapacity    Int
  pricePerKm         Float
  securityDeposit    Float
  pickupLocation     String
  description        String
  registrationNumber String   @unique
  availabilityStatus Boolean  @default(true)

  owner User @relation(fields: [ownerId], references: [id])

  images    VehicleImage[]
  bookings  Booking[]
  reviews   Review[]
  wishlists Wishlist[]

  createdAt DateTime @default(now())
}

model VehicleImage {
  id        String  @id @default(uuid())
  vehicleId String
  imageUrl  String

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}

model Booking {
  id            String   @id @default(uuid())
  vehicleId     String
  userId        String
  pickupDate    DateTime
  returnDate    DateTime
  status        String
  depositAmount Float?
  finalAmount   Float?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  document Document?
  odometer OdometerRecord?
  payment  Payment?

  createdAt DateTime @default(now())
}

model Document {
  id                 String @id @default(uuid())
  bookingId          String @unique
  aadhaarUrl         String
  drivingLicenseUrl  String
  verificationStatus String

  booking Booking @relation(fields: [bookingId], references: [id])
}

model OdometerRecord {
  id             String @id @default(uuid())
  bookingId      String @unique
  pickupReading  Int
  pickupPhoto    String
  returnReading  Int?
  returnPhoto    String?
  distanceDriven Int?

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Payment {
  id                String @id @default(uuid())
  bookingId         String @unique
  razorpayPaymentId String?
  amount            Float
  paymentType       String
  status            String

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Review {
  id        String @id @default(uuid())
  userId    String
  vehicleId String
  rating    Int
  comment   String

  user    User    @relation(fields: [userId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  createdAt DateTime @default(now())
}

model Wishlist {
  id        String @id @default(uuid())
  userId    String
  vehicleId String

  user    User    @relation(fields: [userId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}